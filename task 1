from pyspark.sql import SparkSession
from pyspark.sql import functions as F
import pandas as pd
import numpy as np

# --- STEP 1: INITIALIZE SPARK ---
spark = SparkSession.builder \
    .appName("CodTech_BigData_Task") \
    .getOrCreate()

# --- STEP 2: CREATE A SYNTHETIC LARGE DATASET ---
# Generating 1 million rows to demonstrate scalability
print("Generating 1,000,000 rows of data...")
num_rows = 1000000
data = {
    "Transaction_ID": np.arange(num_rows),
    "Category": np.random.choice(['Electronics', 'Groceries', 'Clothing', 'Home', 'Toys'], num_rows),
    "Amount": np.random.uniform(10.0, 500.0, num_rows),
    "Customer_ID": np.random.randint(1000, 5000, num_rows)
}

# Convert to Spark DataFrame
pdf = pd.DataFrame(data)
df = spark.createDataFrame(pdf)

# --- STEP 3: PERFORM BIG DATA ANALYSIS ---
# In Big Data, we use distributed functions to handle heavy computation
print("\nPerforming distributed aggregations...")

# 1. Calculate total revenue and average transaction per category
analysis = df.groupBy("Category").agg(
    F.count("Transaction_ID").alias("Total_Transactions"),
    F.sum("Amount").alias("Total_Revenue"),
    F.avg("Amount").alias("Avg_Transaction_Value")
).orderBy(F.desc("Total_Revenue"))

# 2. Filtering for "High Value" transactions (e.g., > $450)
high_value_count = df.filter(df.Amount > 450).count()

# --- STEP 4: SHOW INSIGHTS ---
analysis.show()
print(f"Total High-Value Transactions (> $450): {high_value_count}")

# --- STEP 5: VISUALIZE SUMMARY ---
# Convert only the small summary back to Pandas for plotting
chart_data = analysis.toPandas()
import matplotlib.pyplot as plt

plt.figure(figsize=(10,6))
plt.bar(chart_data['Category'], chart_data['Total_Revenue'], color='skyblue')
plt.title("Total Revenue by Category (Analysis of 1 Million Rows)")
plt.ylabel("Revenue")
plt.show()
