trips = []

def add_trip():
    destination = input("Enter destination: ")
    days = int(input("Enter number of days: "))
    budget = float(input("Enter budget: "))

    trip = {
        "destination": destination,
        "days": days,
        "budget": budget
    }

    trips.append(trip)
    print("Trip added successfully!\n")


def view_trips():
    if not trips:
        print("No trips found.\n")
        return

    print("\n--- All Trips ---")
    for i, trip in enumerate(trips, start=1):
        print(f"\nTrip {i}")
        print("Destination:", trip["destination"])
        print("Days:", trip["days"])
        print("Budget:", trip["budget"])


def search_trip():
    destination = input("Enter destination to search: ")

    found = False

    for trip in trips:
        if trip["destination"].lower() == destination.lower():
            print("\nTrip Found")
            print("Destination:", trip["destination"])
            print("Days:", trip["days"])
            print("Budget:", trip["budget"])
            found = True

    if not found:
        print("Trip not found.\n")


def delete_trip():
    destination = input("Enter destination to delete: ")

    for trip in trips:
        if trip["destination"].lower() == destination.lower():
            trips.remove(trip)
            print("Trip deleted successfully!\n")
            return

    print("Trip not found.\n")


while True:
    print("\n===== Traveller Planner =====")
    print("1. Add Trip")
    print("2. View Trips")
    print("3. Search Trip")
    print("4. Delete Trip")
    print("5. Exit")

    choice = input("Enter your choice: ")

    if choice == "1":
        add_trip()
    elif choice == "2":
        view_trips()
    elif choice == "3":
        search_trip()
    elif choice == "4":
        delete_trip()
    elif choice == "5":
        print("Thank you!")
        break
    else:
        print("Invalid choice.")
